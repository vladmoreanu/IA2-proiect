{
    "latex-workshop.latex.outDir": "%WORKSPACE_FOLDER%/.bin/%DOCFILE%/",
    "latex-workshop.latex.auxDir": "%OUTDIR%/aux",
    "latex-workshop.latex.tools": [
        {
            "name": "latexmk",
            "command": "latexmk",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-pdf",
                "-outdir=%OUTDIR%",
                "-auxdir=%AUXDIR%",
                "%DOC%"
            ]
        }
    ],
    "latex-workshop.latex.recipes": [
        {
            "name": "latexmk",
            "tools": [
                "latexmk",
            ]
        }
    ]
}
