{
  "name": "DnCNN",
  "report": "report-{time}.json",
  "dataset": {
    "subset": "tiled_pairs",
    "resize": 1024,
    "blur_params": {
      "kernel_size": 5,
      "kernel_sigma": 10.0
    },
    "noise_sigma": 15.0,
    "tile_size": 128,
    "cache_batch_size": 32
  },
  "dataloader": {
    "batch_size": 16,
    "num_workers": 2,
    "prefetch_factor": 4,
    "pin_memory": true,
    "persistent_workers": true
  },
  "validation": {
    "n_splits": 5
  },
  "model": {
    "num_of_layers": 17
  },
  "optimizer": {
    "lr": 0.001
  },
  "fit": {
    "epochs": 10
  },
  "csv_log": {
    "path": "logs/{time}.csv"
  },
  "checkpoint": {
    "filepath": "checkpoints/{time}.pth",
    "save_best_only": true
  },
  "backup_restore": {
    "dirpath": "backup/{time}",
    "save_every_n_batches": 200,
    "max_batch_saves": 3
  }
}